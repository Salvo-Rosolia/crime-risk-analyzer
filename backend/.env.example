# Configurazione Crime Risk Analyzer — copia in `.env` e compila.
# `.env` è ignorato da git (vedi .gitignore); questo template NO.

# API key LLM — necessarie solo dal layer di generazione (fase P2).
# Lasciare vuote non impedisce l'avvio dell'app.
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Path dell'ontologia TERMINUS Crime caricata a runtime.
# Il default di config punta al file reale (ontology/terminus_crime_materialized.ttl),
# non ancora consegnato dal relatore. Finché manca, per avviare l'app in locale
# puntare alla fixture di sviluppo:
# ONTOLOGY_PATH=tests/fixtures/ontology_sample.ttl
ONTOLOGY_PATH=ontology/terminus_crime_materialized.ttl

# Provider LLM attivo: "claude" oppure "groq".
LLM_PROVIDER=claude

# Timeout (secondi, > 0) del layer LLM: tetto sia sull'SDK sia via wait_for,
# così un provider appeso non blocca /analyze. Scaduto -> fallback strutturato.
LLM_TIMEOUT_SECONDS=30.0

# Tetto di token di output della generazione (>= 1).
LLM_MAX_TOKENS=1024

# Abilita il prompt caching di Anthropic.
CACHE_ENABLED=true

# Città di fallback quando non specificata nella richiesta.
DEFAULT_CITY=Roma

# Allowlist CORS (#106): origini del frontend autorizzate a leggere le risposte
# dell'API. Formato lista JSON, mai wildcard "*" (rifiutato al load). Il deploy
# canonico e' same-origin (build Angular servita da FastAPI): li' il CORS non
# serve; questa lista abilita un eventuale deploy split-origin. Default in dev:
# il dev-server di Angular (ng serve).
# NB: ogni origine e' schema://host[:porta] SENZA slash finale ne' path (un
# trailing slash non matcha mai). Una lista vuota [] disabiliterebbe di fatto il
# CORS ed e' percio' rifiutata al load.
CORS_ALLOW_ORIGINS=["http://localhost:4200"]
